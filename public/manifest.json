{
  "manifest_version": 3,
  "name": "DragOn",
  "version": "0.1.0",
  "description": "Capture selected content as Markdown or an image.",
  "action": {
    "default_title": "DragOn",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "commands",
    "clipboardWrite"
  ],
  "commands": {
    "copy_markdown": {
      "suggested_key": {
        "default": "Alt+Shift+D",
        "mac": "Alt+Shift+D"
      },
      "description": "Copy selection as Markdown"
    },
    "capture_image": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "Alt+Shift+C"
      },
      "description": "Capture selection as image"
    }
  }
}
